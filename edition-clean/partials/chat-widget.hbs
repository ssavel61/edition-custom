{{!--
  Mind Over Money chat widget. Talks to the Cloudflare Worker RAG backend
  (see /chat-agent in the repo). Stays completely hidden until you set
  CHAT_ENDPOINT below to your deployed Worker's /chat URL.
--}}
<style>
  .mom-chat-launcher {
    position: fixed; bottom: 24px; right: 24px; z-index: 99999;
    display: flex; align-items: center; gap: 9px;
    height: 52px; padding: 0 20px 0 17px; border: none; border-radius: 100px;
    background: #2c353c; color: #fff; cursor: pointer;
    box-shadow: 0 8px 22px rgba(44,53,60,0.34);
    font-family: var(--gh-font-body, -apple-system, system-ui, sans-serif);
    font-size: 1.45rem; font-weight: 700; line-height: 1;
    transition: transform .15s ease, background .15s ease;
  }
  .mom-chat-launcher:hover { transform: translateY(-2px); background: #1f262b; }
  .mom-chat-launcher svg { width: 22px; height: 22px; color: #8abfc5; }
  .mom-chat-launcher-label { white-space: nowrap; }

  .mom-chat-panel {
    position: fixed; bottom: 88px; right: 24px; z-index: 100000;
    width: 380px; max-width: calc(100vw - 32px);
    height: 560px; max-height: calc(100vh - 130px);
    background: #fff; border-radius: 16px; overflow: hidden;
    box-shadow: 0 12px 40px rgba(44,53,60,0.25);
    display: none; flex-direction: column;
    font-family: var(--gh-font-body, -apple-system, system-ui, sans-serif);
  }
  .mom-chat-panel.open { display: flex; }

  .mom-chat-header {
    background: #2c353c; color: #fff; padding: 16px 18px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .mom-chat-header h3 { margin: 0; font-size: 1.5rem; font-weight: 700; }
  .mom-chat-header p { margin: 2px 0 0; font-size: 1.2rem; opacity: .7; }
  .mom-chat-close { background: none; border: none; color: #fff; cursor: pointer;
    font-size: 2rem; line-height: 1; opacity: .8; }
  .mom-chat-close:hover { opacity: 1; }

  .mom-chat-body { flex: 1; overflow-y: auto; padding: 16px; background: #f4f6f7; }
  .mom-chat-msg { margin-bottom: 14px; font-size: 1.5rem; line-height: 1.6; }
  .mom-chat-msg .bubble { display: inline-block; padding: 11px 15px; border-radius: 14px; max-width: 92%; text-align: left; }
  .mom-chat-msg.user { text-align: right; }
  .mom-chat-msg.user .bubble { background: #2c353c; color: #fff; border-bottom-right-radius: 4px; }
  .mom-chat-msg.bot .bubble { background: #fff; color: #232c33; border: 1px solid #d7dee1; border-bottom-left-radius: 4px; }
  .mom-chat-msg .bubble strong { font-weight: 700; }
  .mom-chat-sources { margin-top: 8px; }
  .mom-chat-sources a { display: block; font-size: 1.25rem; color: #5a8a90; text-decoration: none; padding: 4px 0; border-top: 1px solid #e1e7e9; }
  .mom-chat-sources a:hover { color: #2c353c; }
  .mom-chat-sources .label { font-size: 1.1rem; text-transform: uppercase; letter-spacing: .04em; color: #9aa7ab; margin-top: 6px; }

  .mom-chat-input { display: flex; gap: 8px; padding: 12px; border-top: 1px solid #e1e7e9; background: #fff; }
  .mom-chat-input textarea {
    flex: 1; resize: none; border: 1px solid #d5dee0; border-radius: 10px;
    padding: 10px 12px; font-size: 1.4rem; font-family: inherit; max-height: 100px;
  }
  .mom-chat-input textarea:focus { outline: none; border-color: #8abfc5; }
  .mom-chat-send { border: none; background: #8abfc5; color: #fff; border-radius: 10px;
    padding: 0 16px; font-weight: 700; cursor: pointer; font-size: 1.4rem; }
  .mom-chat-send:disabled { opacity: .5; cursor: default; }

  @media (max-width: 480px) {
    .mom-chat-panel { left: 8px; right: 8px; width: auto; bottom: 80px; height: calc(100vh - 110px); }
    .mom-chat-launcher { right: 16px; bottom: 16px; }
  }
</style>

<button class="mom-chat-launcher" id="mom-chat-launcher" aria-label="Ask the AI assistant" hidden>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
  <span class="mom-chat-launcher-label">Ask AI</span>
</button>

<div class="mom-chat-panel" id="mom-chat-panel" role="dialog" aria-label="Content assistant">
  <div class="mom-chat-header">
    <div>
      <h3>Ask Mind Over Money</h3>
      <p>Find the right content, fast.</p>
    </div>
    <button class="mom-chat-close" id="mom-chat-close" aria-label="Close">&times;</button>
  </div>
  <div class="mom-chat-body" id="mom-chat-body"></div>
  <div class="mom-chat-input">
    <textarea id="mom-chat-text" rows="1" placeholder="e.g. Where should I start with AI agents?"></textarea>
    <button class="mom-chat-send" id="mom-chat-send">Send</button>
  </div>
</div>

<script>
(function () {
  // 👉 Paste your deployed Worker chat URL here, then commit. Until it's set,
  //    the widget stays hidden.
  var CHAT_ENDPOINT = "https://mindovermoney-chat.mindovermoney-ai.workers.dev/chat";
  if (!CHAT_ENDPOINT) return;

  var launcher = document.getElementById("mom-chat-launcher");
  var panel = document.getElementById("mom-chat-panel");
  var body = document.getElementById("mom-chat-body");
  var input = document.getElementById("mom-chat-text");
  var sendBtn = document.getElementById("mom-chat-send");
  var history = [];
  var busy = false;

  launcher.hidden = false;

  function open(prefill) {
    panel.classList.add("open");
    if (!body.childNodes.length) {
      addBot("Hi! Ask me anything about Santosh's writing on AI — I'll point you to the most useful pieces. What are you working on?");
    }
    if (prefill) { input.value = prefill; send(); }
    else { input.focus(); }
  }
  function close() { panel.classList.remove("open"); }

  // Let other parts of the site (e.g. the homepage buttons) open the chat,
  // optionally asking a question immediately.
  window.MindOverMoneyChat = {
    open: function () { open(); },
    ask: function (q) { open(q); },
    close: close,
    toggle: function () { panel.classList.contains("open") ? close() : open(); },
  };

  launcher.addEventListener("click", function () {
    panel.classList.contains("open") ? close() : open();
  });
  document.getElementById("mom-chat-close").addEventListener("click", close);

  input.addEventListener("input", function () {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 100) + "px";
  });
  input.addEventListener("keydown", function (e) {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); send(); }
  });
  sendBtn.addEventListener("click", send);

  function el(cls, html) {
    var d = document.createElement("div");
    d.className = cls;
    if (html != null) d.innerHTML = html;
    return d;
  }
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function (c) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c];
    });
  }
  // Minimal, safe Markdown -> HTML: escape first, then **bold**, bullets, breaks.
  function renderMarkdown(text) {
    var html = escapeHtml(text);
    html = html.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
    html = html.replace(/(^|\n)\s*[-*]\s+/g, "$1• ");
    html = html.replace(/\n{2,}/g, "<br><br>").replace(/\n/g, "<br>");
    return html;
  }
  function addUser(text) {
    var m = el("mom-chat-msg user");
    m.appendChild(el("bubble", escapeHtml(text)));
    body.appendChild(m);
    body.scrollTop = body.scrollHeight;
  }
  function addBot(text) {
    var m = el("mom-chat-msg bot");
    var b = el("bubble", escapeHtml(text || ""));
    m.appendChild(b);
    body.appendChild(m);
    body.scrollTop = body.scrollHeight;
    return b;
  }

  function send() {
    var text = input.value.trim();
    if (!text || busy) return;
    addUser(text);
    history.push({ role: "user", content: text });
    input.value = "";
    input.style.height = "auto";
    stream();
  }

  function stream() {
    busy = true;
    sendBtn.disabled = true;
    var bubble = addBot("…");
    var answer = "";
    var sources = [];

    fetch(CHAT_ENDPOINT, {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ messages: history }),
    })
      .then(function (res) {
        if (!res.ok || !res.body) throw new Error("Request failed (" + res.status + ")");
        var reader = res.body.getReader();
        var decoder = new TextDecoder();
        var buf = "";

        function pump() {
          return reader.read().then(function (r) {
            if (r.done) return finish();
            buf += decoder.decode(r.value, { stream: true });
            var parts = buf.split("\n\n");
            buf = parts.pop();
            parts.forEach(handleEvent);
            return pump();
          });
        }

        function handleEvent(block) {
          var ev = "", data = "";
          block.split("\n").forEach(function (line) {
            if (line.indexOf("event:") === 0) ev = line.slice(6).trim();
            else if (line.indexOf("data:") === 0) data += line.slice(5).trim();
          });
          if (!data) return;
          if (ev === "sources") {
            try { sources = JSON.parse(data); } catch (e) {}
          } else if (ev === "token") {
            try {
              answer += JSON.parse(data);
              bubble.innerHTML = renderMarkdown(answer);
              body.scrollTop = body.scrollHeight;
            } catch (e) {}
          } else if (ev === "error") {
            bubble.textContent = answer || "Sorry, something went wrong. Please try again.";
          }
        }

        function finish() {
          if (!answer) bubble.textContent = "I couldn't find anything on that yet. Try rephrasing, or browse the archive.";
          history.push({ role: "assistant", content: answer });
          renderSources(bubble.parentNode, sources);
          busy = false;
          sendBtn.disabled = false;
        }

        return pump();
      })
      .catch(function (err) {
        bubble.textContent = "Sorry, I'm having trouble connecting right now.";
        busy = false;
        sendBtn.disabled = false;
      });
  }

  function renderSources(msgEl, sources) {
    if (!sources || !sources.length) return;
    var wrap = el("mom-chat-sources");
    wrap.appendChild(el("label", "Sources"));
    sources.slice(0, 4).forEach(function (s) {
      var a = document.createElement("a");
      a.href = s.url;
      a.textContent = s.title + (s.type ? " — " + s.type : "");
      wrap.appendChild(a);
    });
    msgEl.appendChild(wrap);
    body.scrollTop = body.scrollHeight;
  }
})();
</script>
